# ── Subtitles / STT ────────────────────────────────────────────
# Lemonfox STT API (https://api.lemonfox.ai) — word-level timestamps for captions
# Leave blank to skip subtitle generation
LEMONFOX_API_KEY=

# ── LLM Provider ──────────────────────────────────────────────
# claude.gg (OpenAI-compatible)
CLAUDEGG_API_KEY=your_claudegg_api_key_here

# ── Voice Provider ─────────────────────────────────────────────
# Inworld AI TTS (English)
INWORLD_API_KEY=your_inworld_api_key_here

# CortexAI / router.claude.gg TTS (Turkish, ElevenLabs voices)
CORTEXAI_API_KEY=your_cortexai_api_key_here

# Google Vertex AI TTS (Gemini 2.5 Flash/Pro — TR + EN)
# Uses the same key as CortexAI (CORTEX_API_KEY)
CORTEX_API_KEY=your_cortex_api_key_here

# ── Image Provider ─────────────────────────────────────────────
# Z-Image / kie.ai
ZIMAGE_API_KEY=your_zimage_api_key_here

# Pexels (photos + videos) — https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Google Images scraper — paste your browser's Cookie header value here
# (Open DevTools → Network → any google.com request → Request Headers → Cookie)
# Cookie expires periodically; update when Google returns bot challenge errors
GOOGLE_COOKIES=

# ── Server ─────────────────────────────────────────────────────
PORT=3001
OUTPUT_DIR=output